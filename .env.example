# ============================================================
# TravelVerse Pass — Environment Variables Template
# ============================================================
# Copy file ini ke `.env` lalu isi value-nya.
# JANGAN COMMIT FILE `.env` KE GITHUB!

# ------------------------------------------------------------
# WALLET (untuk deploy contract)
# ------------------------------------------------------------
# Private key dari MetaMask wallet (TANPA prefix 0x).
# Cara export: MetaMask -> Account Details -> Show Private Key
PRIVATE_KEY=

# ------------------------------------------------------------
# POLYGONSCAN (optional, untuk verify contract)
# ------------------------------------------------------------
# Dapatkan API key gratis di: https://etherscan.io/apidashboard
POLYGONSCAN_API_KEY=

# ------------------------------------------------------------
# DEPLOYED CONTRACT ADDRESSES (diisi setelah deploy)
# ------------------------------------------------------------
# Address ketiga contract setelah deploy ke Polygon Amoy.
# Akan di-share ke tim FE untuk integrasi.
TOURIST_PASS_ADDRESS=
BADGE_ADDRESS=
TOKEN_ADDRESS=

# ------------------------------------------------------------
# RPC (optional override)
# ------------------------------------------------------------
# Default: https://rpc-amoy.polygon.technology/
# Bisa diganti dengan Alchemy/Infura kalau RPC default lambat.
AMOY_RPC_URL=
