# ============================================================
# TravelVerse Pass — Backend Environment Variables
# ============================================================
# Copy file ini ke `.env` lalu isi value-nya. JANGAN COMMIT `.env`!

# ------------------------------------------------------------
# SERVER
# ------------------------------------------------------------
PORT=4000
NODE_ENV=development
CORS_ORIGIN=http://localhost:3000

# ------------------------------------------------------------
# BLOCKCHAIN (sama dengan deployer wallet di smart contract)
# ------------------------------------------------------------
AMOY_RPC_URL=https://rpc-amoy.polygon.technology/

# Private key untuk owner signer (yang call onlyOwner functions).
# HARUS sama dengan PRIVATE_KEY di root .env (deployer wallet).
OWNER_PRIVATE_KEY=

# Contract addresses (isi setelah `npm run deploy:amoy` dari root)
TOURIST_PASS_ADDRESS=
BADGE_ADDRESS=
TOKEN_ADDRESS=

# ------------------------------------------------------------
# AUTH (JWT secret)
# ------------------------------------------------------------
# Generate: openssl rand -hex 32
JWT_SECRET=
JWT_EXPIRES_IN=7d

# ------------------------------------------------------------
# QR SECURITY (HMAC signing)
# ------------------------------------------------------------
# Generate: openssl rand -hex 32
QR_SECRET=
QR_TTL_SECONDS=900

# ------------------------------------------------------------
# SUPABASE (Database)
# ------------------------------------------------------------
# Dari dashboard Supabase → Project Settings → API
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
