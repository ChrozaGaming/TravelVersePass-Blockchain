# ============================================================
# TravelVerse Pass — Frontend Environment Variables
# ============================================================
# Copy file ini ke `.env.local` lalu isi value-nya.
# Semua var NEXT_PUBLIC_* di-expose ke browser — JANGAN taruh secret!

# ------------------------------------------------------------
# BACKEND API
# ------------------------------------------------------------
NEXT_PUBLIC_API_URL=http://localhost:4000

# ------------------------------------------------------------
# BLOCKCHAIN (untuk direct contract call: mintPass)
# ------------------------------------------------------------
NEXT_PUBLIC_TOURIST_PASS_ADDRESS=
NEXT_PUBLIC_CHAIN_ID=80002
NEXT_PUBLIC_CHAIN_NAME=Polygon Amoy
NEXT_PUBLIC_CHAIN_RPC=https://rpc-amoy.polygon.technology/
# Hardhat Local gak punya block explorer. Set empty supaya FE skip render link.
# Untuk Polygon Amoy, isi: https://amoy.polygonscan.com
NEXT_PUBLIC_BLOCK_EXPLORER=

# ------------------------------------------------------------
# SUPABASE (optional — kalau FE perlu langsung query DB)
# Kosongkan kalau semua data lewat backend API.
# ------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
